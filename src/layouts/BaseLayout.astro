---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Chris Threlfall – UX/UI Designer' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap" rel="stylesheet" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <ViewTransitions />
    <style>
      #particleCanvas {
        position: fixed; top: 0; left: 0;
        width: 100%; height: 100vh;
        display: block; cursor: pointer; z-index: 0;
      }
      #instructions-container { position: fixed; }
      .job-toggle {
        background: none; border: none; padding: 0; cursor: pointer;
        color: inherit; font-size: inherit; font-family: inherit;
        letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.45;
        margin-bottom: 1.5rem; display: block; transition: opacity 0.2s;
      }
      .job-toggle:hover { opacity: 1; }
      .job-bullets { margin-top: 0.5rem; }
    </style>
  </head>
  <body class="bg-zinc-900 text-white antialiased">

    <!-- <canvas id="particleCanvas" transition:persist="particle-canvas"></canvas> -->

    <div data-scroll-container class="relative z-10">
      <slot />
    </div>

    <script is:inline src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script is:inline src="https://unpkg.co/gsap@3/dist/gsap.min.js"></script>
    <script is:inline src="https://unpkg.com/gsap@3/dist/ScrollTrigger.min.js"></script>
    <script is:inline src="/main.js"></script>

    <!-- Re-run scroll animations on each page transition -->
    <script is:inline>
      document.addEventListener('astro:page-load', function () {
        if (typeof ScrollTrigger !== 'undefined') {
          ScrollTrigger.getAll().forEach(function (t) { t.kill(); });
        }
        if (typeof initScrolltriggerNav === 'function') initScrolltriggerNav();
        if (typeof initScrollLetters === 'function') initScrollLetters();
      });
    </script>

    <script type="importmap" is:inline>
      {
        "imports": {
          "three": "https://cdn.jsdelivr.net/npm/three@0.163.0/build/three.module.js",
          "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.163.0/examples/jsm/"
        }
      }
    </script>

    <!-- Particle system — loads once; canvas persists across navigations -->
    <script type="module" is:inline>
      if (!window.__particleInitialized) {
        window.__particleInitialized = true;
        import('/particle.js');
      }
    </script>

  </body>
</html>
