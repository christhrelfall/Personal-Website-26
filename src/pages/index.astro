---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
---

<BaseLayout title="Chris Threlfall – UX/UI Designer">

  <!-- Hero -->
  <div class="min-h-screen relative z-1 flex flex-col pb-16 justify-between home-header">
    <Header />
    <div class="overflow-hidden mb-[5vh] relative pt-[24vh] md:pt-0 md:pb-[24vh]">
      <p class="container mx-auto px-12 text-5xl 2xl:text-8xl mt-[8vh] pb-1 md:mb-[10vh]">UX/UI<br> Designer</p>
      <div class="big-name absolute left-0 w-full top-0 md:top-auto md:bottom-0">
        <div class="name-h1" data-scroll data-scroll-direction="horizontal" data-scroll-speed="4" data-scroll-position="top">
          <div class="name-wrap">
            <h1 class="no-select once-in once-in-secondary">Chris Threlfall<span class="spacer">—</span></h1>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Content -->
  <div class="container mx-auto px-12 relative z-1">
    <div class="my-64 leading-normal">
      <h1 class="text-5xl 2xl:text-8xl">Design systems, AI-enhanced workflows, and end-to-end UX — built for scale, grounded in people</h1>
    </div>
    <div class="text-2xl 2xl:text-3xl">

      <div class="mb-64">
        <h4 class="font-display uppercase mb-12">&mdash; What I do</h4>
        <p class="leading-normal">I specialise in design system strategy — from creation through to implementation across multiple products — while actively adopting and integrating AI tools to enhance both design and business workflows. My work spans the full end-to-end UX process, from early discovery and user research through to delivery, grounding every decision in usability testing and data. I bring strong visual and interaction design across web, mobile, and enterprise applications, and work closely with product, development, and business stakeholders throughout, taking ownership of projects and delivering within agile environments. With a technical background in HTML, CSS, and JavaScript, I bridge the gap between design and code — and I'm always looking to improve the processes, tools, and standards that help teams do their best work.</p>
      </div>

      <div class="mb-64">
        <h4 class="font-display uppercase mb-12">&mdash; Skills &amp; Expertise</h4>
        <div class="mb-12 leading-normal">
          <h4 class="font-bold mb-6">Design Craft</h4>
          <p>Design System Architecture</p>
          <p>Scalable, Token-driven Design</p>
          <p>Multi-platform Interface Design</p>
          <p>Motion &amp; Interaction Design</p>
        </div>
        <div class="mb-12 leading-normal">
          <h4 class="font-bold mb-6">AI &amp; Innovation</h4>
          <p>AI Adoption &amp; Workflow Integration</p>
          <p>Building AI Tooling for Design Teams</p>
          <p>Figma &amp; Claude AI Integration</p>
          <p>Design-to-Code Sync via AI</p>
        </div>
        <div class="mb-12 leading-normal">
          <h4 class="font-bold mb-6">Design Leadership</h4>
          <p>Design Standards &amp; Governance</p>
          <p>Elevating Quality Collectively</p>
          <p>Mentoring &amp; Team Development</p>
          <p>Building Shared Design Culture</p>
        </div>
        <div class="mb-12 leading-normal">
          <h4 class="font-bold mb-6">UX Practice</h4>
          <p>Discovery &amp; User Research</p>
          <p>Usability Testing &amp; Validation</p>
          <p>Rapid Prototyping &amp; Iteration</p>
          <p>Information Architecture</p>
        </div>
      </div>

      <div class="mb-64">
        <h4 class="font-display uppercase mb-12">&mdash; Tools &amp; Knowledge</h4>
        <div class="mb-12 leading-normal">
          <h4 class="font-bold mb-6">Design</h4>
          <p>Figma</p>
          <p>Adobe</p>
          <p>Protopie</p>
        </div>
        <div class="mb-12 leading-normal">
          <h4 class="font-bold mb-6">AI Tools</h4>
          <p>GitHub Copilot</p>
          <p>Cursor</p>
          <p>ChatGPT</p>
          <p>Claude</p>
        </div>
        <div class="mb-12 leading-normal">
          <h4 class="font-bold mb-6">Collaboration</h4>
          <p>Jira</p>
          <p>Notion</p>
          <p>Confluence</p>
          <p>Monday</p>
          <p>Hotjar</p>
        </div>
        <div class="mb-12 leading-normal">
          <h4 class="font-bold mb-6">Technical</h4>
          <p>React</p>
          <p>HTML</p>
          <p>CSS / Tailwind</p>
          <p>JavaScript</p>
          <p>Version Control</p>
        </div>
      </div>

      <div class="mb-64">
        <h1 class="text-5xl">
          <a href="mailto:hello@christhrelfall.co.uk">
            <span class="block break-words">hello@christhrelfall.co.uk</span>
          </a>
        </h1>
      </div>

    </div>
  </div>

</BaseLayout>
