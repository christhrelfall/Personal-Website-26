---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
---

<BaseLayout title="Resumé – Chris Threlfall">

  <Header />

  <div class="container mx-auto px-12 relative z-1">

    <div class="my-64 leading-normal">
      <h1 class="text-5xl 2xl:text-8xl">25 years designing digital products — from research and strategy through to code and delivery</h1>
    </div>

    <div class="text-2xl 2xl:text-3xl">
      
      <div class="mb-64">
        <h4 class="font-display uppercase mb-12">&mdash; Experience</h4>

        <div class="mb-24 leading-normal">
          <h4 class="font-bold mb-2">Cegedim RX</h4>
          <p class="uppercase mb-6 opacity-50">Senior UI/UX Designer, 2020 – Present</p>
          <p class="mb-6">Joining as the company's most senior designer, I brought together everything built across my career — leading the design practice end-to-end across a suite of complex healthcare software products, driving early AI adoption across the organisation, and embedding modern tools and processes that measurably improved how the team works.</p>
        </div>

        <div class="mb-24 leading-normal">
          <h4 class="font-bold mb-2">Motionlab</h4>
          <p class="uppercase mb-6 opacity-50">Senior UI/UX Designer, May 2012 – 2020</p>
          <p class="mb-6">A pivotal move into digital product design — deepening my UX specialisation across ecommerce and B2C platforms, and growing into a designer who could own projects technically as well as creatively.</p>
        </div>

        <div class="mb-12 leading-normal">
          <h4 class="font-bold mb-2">D-Room</h4>
          <p class="uppercase mb-6 opacity-50">Senior Designer, July 2007 – April 2012</p>
          <p class="mb-6">Progressed from junior to senior level within the same studio — taking on greater ownership of projects, clients, and people as my skills and confidence grew.</p>
        </div>

        <div class="mb-24 leading-normal">
          <p class="uppercase mb-6 opacity-50">Graphic Designer, July 2001 – July 2007</p>
          <p class="mb-6">Where it all began — building core visual and communication skills across a diverse range of clients and disciplines.</p>
        </div>

      </div>

      <div class="mb-64">
        <h4 class="font-display uppercase mb-12">&mdash; Education</h4>
        <div class="mb-12 leading-normal">
          <h4 class="font-bold mb-2">BA Hons Graphic Design</h4>
          <p class="uppercase mb-6 opacity-50">University of Bolton, 1998 – 2001</p>
        </div>
      </div>

      <div class="mb-64">
        <h4 class="font-display uppercase mb-12">&mdash; Awards</h4>
        <div class="mb-12 leading-normal">
          <h4 class="font-bold mb-2">Pharmacy Product of the Year</h4>
          <p class="uppercase mb-6 opacity-50">Pharmacy Manager, 2021 &amp; 2022</p>
        </div>
        <div class="mb-12 leading-normal">
          <h4 class="font-bold mb-2">Awwwards Honorable Mention</h4>
          <p class="uppercase mb-6 opacity-50">Oliver Harvey Website, 2014</p>
        </div>
      </div>

      <div class="mb-64">
        <h1 class="text-5xl">
          <a href="mailto:hello@christhrelfall.co.uk">
            <span class="block break-words">hello@christhrelfall.co.uk</span>
          </a>
        </h1>
      </div>

    </div>
  </div>


</BaseLayout>
